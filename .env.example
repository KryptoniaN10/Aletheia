# ── Stellar Network ──────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── Issuer / Admin Account ────────────────────────────────────────
# Generate with: soroban keys generate issuer --network testnet
ISSUER_PUBLIC_KEY=
ISSUER_SECRET_KEY=

# ── Oracle / Admin Account (for confirm_payment) ──────────────────
ORACLE_PUBLIC_KEY=
ORACLE_SECRET_KEY=

# ── Contract IDs (populated by deploy-contracts.sh) ───────────────
RECEIVABLE_REGISTRY_CONTRACT_ID=
FRACTIONAL_SALE_CONTRACT_ID=
SETTLEMENT_ESCROW_CONTRACT_ID=

# ── Off-chain API ─────────────────────────────────────────────────
PORT=3001
DATABASE_URL=./malabar.db

# ── IPFS (Pinata) ─────────────────────────────────────────────────
PINATA_API_KEY=
PINATA_SECRET_KEY=

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_STELLAR_NETWORK=testnet
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
